# Supabase Credentials (Get these from your Supabase Dashboard -> Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Vercel Deploy Hook URL (Get this from Vercel -> Settings -> Git -> Deploy Hooks)
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/prj_xxx/xxx
