---
interface Props {
  lang?: 'ca' | 'es';
}
const { lang = 'ca' } = Astro.props;

const t = {
  ca: {
    desc: "Treballant per la millora del barri i la cohesió social des de 1978. Construint un futur compartit sobre el nostre llegat industrial.",
    navTitle: "Navegació",
    navHistory: "Història",
    navNews: "Notícies",
    navServices: "Serveis",
    navContact: "Contacte",
    legalTitle: "Legal",
    legalNotice: "Avís Legal",
    legalPrivacy: "Privacitat",
    legalCookies: "Cookies",
    legalArchive: "Arxiu",
    contactTitle: "Contacte",
    rights: "© 2024 Associació de Veïns Eixample Sabadell. Tots els drets reservats."
  },
  es: {
    desc: "Trabajando por la mejora del barrio y la cohesión social desde 1978. Construyendo un futuro compartido sobre nuestro legado industrial.",
    navTitle: "Navegación",
    navHistory: "Historia",
    navNews: "Noticias",
    navServices: "Servicios",
    navContact: "Contacto",
    legalTitle: "Legal",
    legalNotice: "Aviso Legal",
    legalPrivacy: "Privacidad",
    legalCookies: "Cookies",
    legalArchive: "Archivo",
    contactTitle: "Contacto",
    rights: "© 2024 Asociación de Vecinos Eixample Sabadell. Todos los derechos reservados."
  }
}[lang];

const prefix = lang === 'es' ? '/es' : '';
---

<footer class="bg-surface-container-low border-t border-outline-variant relative overflow-hidden group/footer">
  <!-- Old Map Style Monster Decor -->
  <div class="absolute bottom-[-30px] right-[-20px] md:right-4 w-60 h-60 md:w-96 md:h-96 pointer-events-none select-none z-0 transition-all duration-700">
    <img 
      src="/monster1.png" 
      alt="Mascota Eixample Sabadell" 
      class="w-full h-full object-contain mascot-old-map"
    />
  </div>

  <div class="flex flex-col md:flex-row justify-between items-start py-16 px-margin-mobile md:px-margin-desktop max-w-max-width mx-auto gap-12 w-full relative z-10">
    <div class="max-w-sm flex flex-col items-start w-full">
      <!-- SVG Filter to colorize the logo in the primary color -->
      <svg class="absolute w-0 h-0 pointer-events-none" style="visibility: hidden" aria-hidden="true">
        <defs>
          <filter id="footer-colorize-mint" x="0" y="0" width="100%" height="100%">
            <feColorMatrix type="matrix" values="
              0 0 0 0 0.215
              0 0 0 0 0.392
              0 0 0 0 0.365
              -1 0 0 0 1
            " result="colorized" />
            <feComposite operator="in" in="colorized" in2="SourceGraphic" />
          </filter>
        </defs>
      </svg>
      <div class="mb-6">
        <img 
          src="/logo.png" 
          alt="Eixample Sabadell" 
          class="h-[70px] w-auto object-contain" 
          style="filter: url(#footer-colorize-mint)"
        />
      </div>
      <p class="font-body-md text-body-md text-on-secondary-container">
        {t.desc}
      </p>
    </div>
    
    <div class="grid grid-cols-2 gap-12 md:gap-24">
      <div class="flex flex-col gap-4">
        <span class="font-label-md text-label-md text-on-surface uppercase tracking-widest font-extrabold mb-2">{t.navTitle}</span>
        <a class="font-label-sm text-label-sm text-on-secondary-container hover:text-primary transition-colors font-medium" href={`${prefix || '/'}`}>Home</a>
        <a class="font-label-sm text-label-sm text-on-secondary-container hover:text-primary transition-colors font-medium" href={`${prefix}/historia`}>{t.navHistory}</a>
        <a class="font-label-sm text-label-sm text-on-secondary-container hover:text-primary transition-colors font-medium" href={`${prefix}/noticies`}>{t.navNews}</a>
      </div>
      <div class="flex flex-col gap-4">
        <span class="font-label-md text-label-md text-on-surface uppercase tracking-widest font-extrabold mb-2">{t.legalTitle}</span>
        <a class="font-label-sm text-label-sm text-on-secondary-container hover:text-primary transition-colors font-medium" href="#">{t.legalNotice}</a>
        <a class="font-label-sm text-label-sm text-on-secondary-container hover:text-primary transition-colors font-medium" href="#">{t.legalPrivacy}</a>
        <a class="font-label-sm text-label-sm text-on-secondary-container hover:text-primary transition-colors font-medium" href="#">{t.legalCookies}</a>
        <a class="font-label-sm text-label-sm text-on-secondary-container hover:text-primary transition-colors font-medium" href="#">{t.legalArchive}</a>
      </div>
    </div>
    
    <div class="flex flex-col gap-6" id="contacte">
      <span class="font-label-md text-label-md text-on-surface uppercase tracking-widest font-extrabold mb-2">{t.contactTitle}</span>
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-primary">location_on</span>
        <span class="font-label-sm text-label-sm text-on-secondary-container font-medium">C/ de la República, 45, 08202 Sabadell</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-primary">mail</span>
        <span class="font-label-sm text-label-sm text-on-secondary-container font-medium">hola@eixamplesabadell.cat</span>
      </div>
    </div>
  </div>
  
  <div class="max-w-max-width mx-auto px-margin-mobile md:px-margin-desktop py-8 border-t border-outline-variant/30 flex flex-col md:flex-row justify-between items-center gap-4 w-full relative z-10">
    <p class="font-label-sm text-label-sm text-on-secondary-container text-center md:text-left font-medium">
      {t.rights}
    </p>
    <div class="flex gap-4">
      <div class="w-8 h-8 rounded-full bg-primary/5 flex items-center justify-center hover:bg-primary/10 cursor-pointer transition-colors" aria-label="Compartir">
        <span class="material-symbols-outlined text-primary text-xl">share</span>
      </div>
      <div class="w-8 h-8 rounded-full bg-primary/5 flex items-center justify-center hover:bg-primary/10 cursor-pointer transition-colors" aria-label="Canal RSS">
        <span class="material-symbols-outlined text-primary text-xl">rss_feed</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .mascot-old-map {
    opacity: 0.35;
    filter: sepia(35%) contrast(90%) brightness(95%);
    animation: mapFloat 8s ease-in-out infinite;
    transition: all 0.7s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  /* Fade in to full color and opacity when the footer is hovered */
  .group\/footer:hover .mascot-old-map {
    opacity: 0.95;
    filter: sepia(0%) contrast(100%) brightness(100%) drop-shadow(0 10px 15px rgba(0, 0, 0, 0.1));
  }

  @keyframes mapFloat {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-12px) rotate(2deg);
    }
  }
</style>
