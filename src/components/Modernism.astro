---
interface Props {
  lang?: 'ca' | 'es';
}
const { lang = 'ca' } = Astro.props;

const t = {
  ca: {
    category: "Arquitectura",
    titlePrefix: "L'Elegància del",
    titleItalic: "Modernisme",
    body: "L'èxit industrial va portar una nova burgesia que va voler reflectir el seu estatus a través de l'art. L'Eixample es va omplir de façanes ornamentades, ferro forjat i mosaics que trencaven la monotonia industrial amb línies corbes i motius florals.",
    item1Title: "Artesania Única",
    item1Desc: "Treball meticulós en vidre, ceràmica i fusta noble.",
    item2Title: "Cases Senyorials",
    item2Desc: "Residències que definien el prestigi dels capitans d'indústria."
  },
  es: {
    category: "Arquitectura",
    titlePrefix: "La Elegancia del",
    titleItalic: "Modernismo",
    body: "El éxito industrial trajo una nueva burguesía que quiso reflejar su estatus a través del arte. El Eixample se llenó de fachadas ornamentadas, hierro forjado y mosaicos que rompían la monotonía industrial con líneas curvas y motivos florales.",
    item1Title: "Artesanía Única",
    item1Desc: "Trabajo meticuloso en vidrio, cerámica y madera noble.",
    item2Title: "Casas Señoriales",
    item2Desc: "Residencias que definían el prestigio de los capitanes de industria."
  }
}[lang];
---

<section class="py-24 bg-white relative overflow-hidden">
  <div class="max-w-max-width mx-auto px-margin-mobile md:px-margin-desktop grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div class="relative w-full">
      <div class="absolute -top-10 -left-10 w-40 h-40 bg-primary-fixed-dim/20 rounded-full blur-3xl z-0"></div>
      <img 
        alt="Catalan Modernism facade" 
        class="rounded-2xl shadow-2xl relative z-10 w-full aspect-[4/5] object-cover" 
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuAgBsqhJergu2aENKrydmGpHHgfZZhw042lbYPxd5o1byGP6oSN0_9YLtGmd6Ay2WmZPgUlRKtRqGn4v5vnWZQq57q0xmcNHyDpFAIJJDs-X-wGLopF6SX9BpPsufiYhi_0dp3PoioHNghWpC29UiKsvjV-y_GaNE0VTzfduD8m_Lf-_VlclPY-Mg2hf9PdNw-h8lfS1Y2wr9r5A2H3-JInbnlIJo6b7W-g4SxgBYoIyc5U8rKIwcqP8CJCljZobI31qyshxKsnslg_"
      />
    </div>
    <div class="w-full relative z-10">
      <span class="text-primary font-label-md uppercase tracking-[0.2em] mb-4 block font-semibold">{t.category}</span>
      <h2 class="font-display-lg text-4xl sm:text-5xl text-on-surface mb-8 leading-tight font-extrabold">
        {t.titlePrefix} <span class="text-primary italic font-serif">{t.titleItalic}</span>
      </h2>
      <p class="font-body-lg text-body-lg text-on-surface-variant mb-8 leading-relaxed">
        {t.body}
      </p>
      <ul class="space-y-6">
        <li class="flex gap-4 items-start">
          <div class="w-12 h-12 rounded-full bg-secondary-fixed flex-shrink-0 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary">palette</span>
          </div>
          <div>
            <h5 class="font-label-md text-primary font-bold text-base">{t.item1Title}</h5>
            <p class="text-on-surface-variant text-sm mt-0.5">{t.item1Desc}</p>
          </div>
        </li>
        <li class="flex gap-4 items-start">
          <div class="w-12 h-12 rounded-full bg-secondary-fixed flex-shrink-0 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary">home_work</span>
          </div>
          <div>
            <h5 class="font-label-md text-primary font-bold text-base">{t.item2Title}</h5>
            <p class="text-on-surface-variant text-sm mt-0.5">{t.item2Desc}</p>
          </div>
        </li>
      </ul>
    </div>
  </div>
</section>
