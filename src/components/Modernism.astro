---
interface Props {
  lang?: 'ca' | 'es';
}
const { lang = 'ca' } = Astro.props;

const t = {
  ca: {
    category: "Llegenda Urbana",
    titlePrefix: "El Monstre de les",
    titleItalic: "Clavegueres",
    body: "El setembre de 1981, el carrer Brutau de l'Eixample va viure un dels capítols més insòlits de la seva història. Després d'un embossament al clavegueram del Bar Sans, es va extreure una criatura viscosa de 4 metres de llargada amb aspecte de calamar gegant. El veterinari municipal va arribar a parlar d'una possible mutació abans que es descobrís la veritat: eren budells de cavall en descomposició. La llegenda del 'Bitxo de Sabadell', però, ja s'havia quedat per sempre al barri.",
    item1Title: "La Histèria Col·lectiva",
    item1Desc: "La policia i desenes de curiosos es van aplegar al voltant del clavegueram del carrer Brutau.",
    item2Title: "El Bar Sans",
    item2Desc: "El punt zero de l'Eixample on es va originar un dels misteris més comentats de la Catalunya dels 80."
  },
  es: {
    category: "Leyenda Urbana",
    titlePrefix: "El Monstruo de las",
    titleItalic: "Cloacas",
    body: "En septiembre de 1981, la calle Brutau del Eixample vivió uno de los capítulos más insólitos de su historia. Tras un atasco en las tuberías del Bar Sans, se extrajo una criatura viscosa de 4 metros de largo con aspecto de calamar gigante. El veterinario municipal llegó a hablar de una posible mutación antes de que se descubriera la verdad: eran intestinos de caballo en descomposición. Sin embargo, la leyenda del 'Bicho de Sabadell' ya se había quedado para siempre en el barrio.",
    item1Title: "La Histeria Colectiva",
    item1Desc: "La policía y decenas de curiosos se agolparon alrededor del alcantarillado de la calle Brutau.",
    item2Title: "El Bar Sans",
    item2Desc: "El punto cero del Eixample donde se originó uno de los misterios más comentados de la Cataluña de los 80."
  }
}[lang];
---

<section class="py-24 bg-white relative overflow-hidden">
  <div class="max-w-max-width mx-auto px-margin-mobile md:px-margin-desktop grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div class="relative w-full">
      <div class="absolute -top-10 -left-10 w-40 h-40 bg-primary-fixed-dim/20 rounded-full blur-3xl z-0"></div>
      <img 
        alt="Sewer Monster of Sabadell 1981" 
        class="rounded-2xl shadow-2xl relative z-10 w-full aspect-[4/5] object-cover" 
        src="/sewer_monster_sabadell.png"
      />
    </div>
    <div class="w-full relative z-10">
      <span class="text-primary font-label-md uppercase tracking-[0.2em] mb-4 block font-semibold">{t.category}</span>
      <h2 class="font-display-lg text-4xl sm:text-5xl text-on-surface mb-8 leading-tight font-extrabold">
        {t.titlePrefix} <span class="text-primary italic font-serif">{t.titleItalic}</span>
      </h2>
      <p class="font-body-lg text-body-lg text-on-surface-variant mb-8 leading-relaxed">
        {t.body}
      </p>
      <ul class="space-y-6">
        <li class="flex gap-4 items-start">
          <div class="w-12 h-12 rounded-full bg-secondary-fixed flex-shrink-0 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary">groups</span>
          </div>
          <div>
            <h5 class="font-label-md text-primary font-bold text-base">{t.item1Title}</h5>
            <p class="text-on-surface-variant text-sm mt-0.5">{t.item1Desc}</p>
          </div>
        </li>
        <li class="flex gap-4 items-start">
          <div class="w-12 h-12 rounded-full bg-secondary-fixed flex-shrink-0 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary">local_bar</span>
          </div>
          <div>
            <h5 class="font-label-md text-primary font-bold text-base">{t.item2Title}</h5>
            <p class="text-on-surface-variant text-sm mt-0.5">{t.item2Desc}</p>
          </div>
        </li>
      </ul>
    </div>
  </div>
</section>
