---
import { getArticles } from '../utils/news';

interface Props {
  lang?: 'ca' | 'es';
}
const { lang = 'ca' } = Astro.props;

const t = {
  ca: {
    title: "Notícies i Activitats",
    desc: "Mantén-te al dia del que passa al carrer.",
    viewAll: "Veure tot",
    viewAllHref: "/noticies"
  },
  es: {
    title: "Noticias y Actividades",
    desc: "Mantente al día de lo que pasa en la calle.",
    viewAll: "Ver todo",
    viewAllHref: "/es/noticies"
  }
}[lang];

const allArticles = await getArticles();
// Sort by date descending and get the 3 most recent
const articles = [...allArticles]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);

// Helper to format date
const formatDate = (dateStr: string) => {
  const dateObj = new Date(dateStr);
  const options: Intl.DateTimeFormatOptions = { day: 'numeric', month: 'short' };
  return dateObj.toLocaleDateString(lang === 'es' ? 'es-ES' : 'ca-ES', options);
};
---

<section class="py-24" id="noticies">
  <div class="max-w-max-width mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="flex justify-between items-end mb-12">
      <div>
        <h2 class="font-headline-lg text-headline-lg text-on-surface mb-2 tracking-tight">{t.title}</h2>
        <p class="font-body-md text-on-surface-variant">{t.desc}</p>
      </div>
      <a class="font-label-md text-label-md text-primary flex items-center gap-2 group px-4 py-2 hover:bg-primary/5 rounded-full transition-all font-bold" href={t.viewAllHref}>
        {t.viewAll} <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {articles.map((article) => {
        const prefix = lang === 'es' ? '/es' : '';
        const articleHref = `${prefix}/noticies/${article.slug[lang]}`;
        return (
          <a href={articleHref} class="flex flex-col group cursor-pointer">
            <div class="aspect-[4/3] mb-6 overflow-hidden rounded-2xl border border-outline-variant">
              <img 
                alt={article.alt[lang]} 
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" 
                src={article.image}
                onerror="this.onerror=null; this.src='/og-image.png';"
              />
            </div>
            <div class="px-2 text-left">
              <span class="font-label-sm text-label-sm text-primary mb-3 block font-extrabold uppercase tracking-[0.1em]">
                {article.category[lang]} • {formatDate(article.date)}
              </span>
              <h3 class="font-headline-sm text-headline-sm text-on-surface mb-3 leading-tight group-hover:text-primary transition-colors tracking-tight line-clamp-2">
                {article.title[lang]}
              </h3>
              <p class="font-body-md text-on-surface-variant line-clamp-2">
                {article.description[lang]}
              </p>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
