---
interface Props {
  lang?: 'ca' | 'es';
}
const { lang = 'ca' } = Astro.props;

const t = {
  ca: {
    title: "Cronologia Industrial",
    e1Title: "L'Alba del Vapor",
    e1Body: "L'arribada del ferrocarril i les primeres màquines de vapor transformen l'Eixample en un formiguer d'activitat. Les primeres \"Vapors\" comencen a dominar l'horitzó.",
    e2Title: "L'Edat d'Or Tèxtil",
    e2Body: "Sabadell esdevé la \"Manchester Catalana\". Els telers no descansen i l'Eixample creix seguint un traçat ortogonal que defineix la seva identitat moderna."
  },
  es: {
    title: "Cronología Industrial",
    e1Title: "El Alba del Vapor",
    e1Body: "La llegada del ferrocarril y las primeras máquinas de vapor transforman el Eixample en un hervidero de actividad. Los primeros \"Vapores\" empiezan a dominar el horizonte.",
    e2Title: "La Edad de Oro Textil",
    e2Body: "Sabadell se convierte en la \"Manchester Catalana\". Los telares no descansan y el Eixample crece siguiendo un trazado ortogonal que define su identidad moderna."
  }
}[lang];
---

<section class="py-24 bg-surface-container-lowest overflow-hidden">
  <div class="max-w-max-width mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="mb-20 text-center">
      <h2 class="font-headline-lg text-headline-lg text-primary mb-4 tracking-tight">{t.title}</h2>
      <div class="h-1 w-24 bg-primary mx-auto rounded-full"></div>
    </div>
    
    <div class="relative w-full">
      {/* Central Line for desktop */}
      <div class="absolute left-1/2 -translate-x-1/2 w-0.5 h-full industrial-line hidden md:block z-0"></div>
      
      {/* Event 1 */}
      <div class="relative mb-24 md:flex items-center justify-between w-full">
        <div class="md:w-[45%] mb-8 md:mb-0 order-1 md:order-1 text-right z-10">
          <span class="font-display-lg text-3xl text-primary opacity-50 block mb-2 font-bold">1850 - 1880</span>
          <h3 class="font-headline-md text-headline-md text-on-surface mb-3 tracking-tight">{t.e1Title}</h3>
          <p class="text-on-surface-variant leading-relaxed font-body-md text-base">
            {t.e1Body}
          </p>
        </div>
        <div class="z-20 absolute left-1/2 -translate-x-1/2 bg-primary w-4 h-4 rounded-full border-4 border-surface-container-lowest hidden md:block"></div>
        <div class="md:w-[45%] order-2 md:order-2 z-10">
          <img 
            alt="Antique factory gears" 
            class="rounded-xl shadow-lg w-full aspect-video object-cover grayscale hover:grayscale-0 transition-all duration-700" 
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuC22i1ndTX4SrfJGX-KDmtKkgVdzSV559uFnyYHXCPoNptc8CYHGwvmt34jJV2Q8Dz3hJQ2rrMLg_jpWECyt04XdPIaQ3JkDp7tBGJv0k_ClSsNOGIe1-Gg8K1WbRYv6BaNUthz8A2fvENZYh7ECO18AgOEAhr85U1M2snajex_idHSpo9kpweRVlTjxpnEijBQqup-__afKFfMJUcRWYRgJhZQPOUk73auL4OYg9XGcWoYyJ2zVt_B9CHaXzKbHrngoJyftmLDLBgD"
          />
        </div>
      </div>
      
      {/* Event 2 */}
      <div class="relative mb-24 md:flex items-center justify-between w-full">
        <div class="md:w-[45%] mb-8 md:mb-0 order-1 md:order-2 text-left z-10">
          <span class="font-display-lg text-3xl text-primary opacity-50 block mb-2 font-bold">1890 - 1920</span>
          <h3 class="font-headline-md text-headline-md text-on-surface mb-3 tracking-tight">{t.e2Title}</h3>
          <p class="text-on-surface-variant leading-relaxed font-body-md text-base">
            {t.e2Body}
          </p>
        </div>
        <div class="z-20 absolute left-1/2 -translate-x-1/2 bg-primary w-4 h-4 rounded-full border-4 border-surface-container-lowest hidden md:block"></div>
        <div class="md:w-[45%] order-2 md:order-1 z-10">
          <img 
            alt="Textile factory looms" 
            class="rounded-xl shadow-lg w-full aspect-video object-cover grayscale hover:grayscale-0 transition-all duration-700" 
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBuINN-nK-qt0E5NIQrVCsTccN8Ic_tdrp3mJxbtt4gfi_pR6wuyMlXWzNeL1Xh1V3hV84cPqiMjFeRQEmkqjFRgHdyIcqETrS_gqQF-SFnbop6b4L-W5mjvqJqv1CG3J0_0jzPb9QD3ugPXihoYLFoyLXyOAcMoOhT2O6F-qAC8rrOuj8KmLn37lx16NUN7WdPLslpkng-UaIumWREEDGLmSdQXmNvXIun4Y0hvwpmUfaQJFEbsZ6zVg1bz1J_5bdpjI-24dfEPU2x"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .industrial-line {
    background: linear-gradient(to bottom, transparent, #37645d 15%, #37645d 85%, transparent);
  }
</style>
