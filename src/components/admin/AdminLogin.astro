<!-- Admin Login Component -->
<div id="login-view" class="w-full max-w-md mx-auto bg-surface-container border border-outline-variant/35 rounded-3xl p-8 sm:p-10 shadow-lg">
  <div class="text-center mb-8">
    <h1 id="login-title" class="font-display-lg text-2xl sm:text-3xl font-extrabold text-primary mb-2">Panel de Control</h1>
    <p id="login-sub" class="font-body-md text-on-surface-variant text-sm">Inicia sessió per gestionar les notícies de l'Eixample Sabadell</p>
  </div>

  <form id="login-form" class="flex flex-col gap-6">
    <div class="flex flex-col gap-1.5">
      <label id="label-email" for="email" class="font-label-md text-sm font-semibold text-on-surface">Correu electrònic</label>
      <input 
        type="email" 
        id="email" 
        required 
        placeholder="nom@exemple.com" 
        class="w-full px-4 py-3 rounded-lg bg-surface-container-low border border-outline-variant/40 outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
      />
    </div>

    <div class="flex flex-col gap-1.5">
      <label id="label-password" for="password" class="font-label-md text-sm font-semibold text-on-surface">Contrasenya</label>
      <input 
        type="password" 
        id="password" 
        required 
        placeholder="••••••••" 
        class="w-full px-4 py-3 rounded-lg bg-surface-container-low border border-outline-variant/40 outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
      />
    </div>

    <button 
      type="submit" 
      id="btn-login"
      class="w-full bg-primary hover:bg-primary-container text-white py-4 rounded-xl font-label-md font-bold transition-all shadow-md active:scale-95 flex items-center justify-center gap-2 mt-2"
    >
      <span id="btn-login-text">Iniciar Sessió</span>
      <span class="material-symbols-outlined text-xl">login</span>
    </button>
  </form>
</div>

<script>
  import { createClient } from '@supabase/supabase-js';

  const configEl = document.getElementById('admin-config')!;
  const supabaseUrl = configEl.getAttribute('data-supabase-url') || '';
  const supabaseKey = configEl.getAttribute('data-supabase-key') || '';
  const supabase = supabaseUrl && supabaseKey ? createClient(supabaseUrl, supabaseKey) : null;

  const viewLogin = document.getElementById('login-view')!;
  const loginForm = document.getElementById('login-form') as HTMLFormElement;

  let activeLang = localStorage.getItem("admin_lang") || "ca";

  const triggerToast = (message: string, isError = false) => {
    window.dispatchEvent(new CustomEvent('admin-show-toast', { detail: { message, isError } }));
  };

  // Check initial session
  const checkUserSession = async () => {
    if (!supabase) {
      triggerToast(activeLang === 'ca' 
        ? 'Configuració de Supabase pendent en les variables d\'entorn.' 
        : 'Configuración de Supabase pendiente en las variables de entorno.', true);
      return;
    }
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      viewLogin.classList.add('hidden');
      window.dispatchEvent(new CustomEvent('admin-login-success'));
    }
  };

  // Handle Login form
  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!supabase) {
      triggerToast('Configuració de Supabase pendent.', true);
      return;
    }
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;

    const { data, error } = await supabase.auth.signInWithPassword({ email, password });
    if (error) {
      triggerToast((activeLang === 'ca' ? 'Error en iniciar sessió: ' : 'Error al iniciar sesión: ') + error.message, true);
    } else {
      triggerToast(activeLang === 'ca' ? 'Sessió iniciada correctament!' : '¡Sesión iniciada correctamente!');
      viewLogin.classList.add('hidden');
      window.dispatchEvent(new CustomEvent('admin-login-success'));
    }
  });

  // Listen to logout
  window.addEventListener('admin-logout', async () => {
    if (!supabase) return;
    const { error } = await supabase.auth.signOut();
    if (error) {
      triggerToast(activeLang === 'ca' ? 'Error al tancar sessió' : 'Error al cerrar sesión', true);
    } else {
      triggerToast(activeLang === 'ca' ? 'Sessió tancada' : 'Sesión cerrada');
      viewLogin.classList.remove('hidden');
    }
  });

  // Listen to language change
  window.addEventListener("admin-lang-change", (e: any) => {
    activeLang = e.detail;
  });

  // Init check
  checkUserSession();
</script>
