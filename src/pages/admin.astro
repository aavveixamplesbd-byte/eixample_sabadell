---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer.astro';
import AdminToast from '../components/admin/AdminToast.astro';
import AdminLogin from '../components/admin/AdminLogin.astro';
import AdminDashboard from '../components/admin/AdminDashboard.astro';
import AdminForm from '../components/admin/AdminForm.astro';

const supabaseUrl = import.meta.env.SUPABASE_URL || '';
const supabaseKey = import.meta.env.SUPABASE_ANON_KEY || '';
const vercelDeployHook = import.meta.env.VERCEL_DEPLOY_HOOK || '';
---

<Layout title="Panell d'Administració - Eixample Sabadell" lang="ca">
  <Navbar client:load />

  <main 
    id="admin-config" 
    data-supabase-url={supabaseUrl} 
    data-supabase-key={supabaseKey} 
    data-vercel-hook={vercelDeployHook}
    class="min-h-screen py-16 px-margin-mobile md:px-margin-desktop max-w-5xl mx-auto w-full flex flex-col justify-center"
  >
    <!-- Toast notifications -->
    <AdminToast />

    <!-- 1. LOGIN SCREEN -->
    <AdminLogin />

    <!-- 2. DASHBOARD VIEW -->
    <AdminDashboard />

    <!-- 3. FORM VIEW -->
    <AdminForm />
  </main>
  
  <Footer lang="ca" />
</Layout>
