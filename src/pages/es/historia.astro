---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import HistoryHero from '../../components/HistoryHero.astro';
import Timeline from '../../components/Timeline.astro';
import Modernism from '../../components/Modernism.astro';
import ModernismGallery from '../../components/ModernismGallery.astro';
import FloodLegend from '../../components/FloodLegend.astro';
import Footer from '../../components/Footer.astro';

const t = {
  title: "Preservemos nuestra memoria",
  desc: "La Asociación de Vecinos trabaja para proteger el legado histórico del Eixample. Únete a nosotros en las visitas guiadas por el patrimonio industrial.",
  btn1: "Reservar Visita",
  btn2: "Ver el Archivo"
};

const navItems = [
  { id: "cronologia-industrial", label: "Cronología Industrial" },
  { id: "monstre-clavegueres", label: "El Bicho de Sabadell" },
  { id: "riuada-62", label: "La Riada del 62" }
];
---

<Layout title="Historia - Eixample Sabadell" lang="es">
  <Navbar client:load />
  
  {/* Sidebar - fixed left on desktop */}
  <nav class="hidden md:block fixed left-0 top-0 h-screen w-64 z-40 pt-24 pb-8 overflow-y-auto bg-surface-container-lowest border-r border-outline-variant/10">
    <div class="px-6">
      <span class="font-label-md uppercase tracking-[0.2em] text-primary font-semibold text-xs block mb-6">
        En esta página
      </span>
      
      <ul class="space-y-1">
        {navItems.map((item) => (
          <li>
            <a
              href={`#${item.id}`}
              class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-on-surface-variant hover:text-primary hover:bg-primary/5 transition-all duration-200 border-l-2 border-transparent hover:border-primary"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      
      <div class="mt-8 pt-6 border-t border-outline-variant/10">
        <p class="text-xs text-on-surface-variant leading-relaxed">
          Haz clic en una sección para desplazarte rápidamente.
        </p>
      </div>
    </div>
  </nav>

  {/* Mobile bottom nav */}
  <div class="md:hidden fixed bottom-0 left-0 right-0 z-40 bg-white border-t border-outline-variant/10 shadow-lg px-4 py-3 flex justify-around">
    {navItems.map((item) => (
      <a
        href={`#${item.id}`}
        class="flex flex-col items-center gap-0.5 text-xs text-on-surface-variant hover:text-primary transition-colors font-medium"
      >
        <span class="font-medium truncate max-w-[80px]">{item.label}</span>
      </a>
    ))}
  </div>

  {/* Main content - offset left for sidebar on desktop */}
  <main class="md:ml-64 pb-16 md:pb-0">
    <Breadcrumbs lang="es" items={[{ label: 'Historia' }]} />
    <HistoryHero lang="es" />
    <Timeline lang="es" />
    <Modernism lang="es" />
    <ModernismGallery lang="es" />
    <FloodLegend lang="es" />

    {/* Custom History CTA Section */}
    <section class="py-24 px-margin-mobile md:px-margin-desktop max-w-max-width mx-auto w-full">
      <div class="bg-inverse-surface rounded-[32px] p-8 sm:p-12 md:p-24 relative overflow-hidden text-center">
        <div class="absolute top-0 right-0 w-96 h-96 bg-primary-container/20 blur-[120px]"></div>
        <div class="relative z-10">
          <h2 class="font-display-lg text-3xl sm:text-4xl md:text-5xl text-white mb-6 font-extrabold tracking-tight">
            {t.title}
          </h2>
          <p class="text-surface-variant max-w-2xl mx-auto mb-12 text-base sm:text-lg leading-relaxed text-gray-300">
            {t.desc}
          </p>
          <div class="flex flex-wrap justify-center gap-4 sm:gap-6">
            <button class="bg-primary hover:bg-primary-container text-white px-8 py-4 rounded-xl font-label-md text-base font-bold transition-all shadow-lg hover:shadow-primary/20 active:scale-98">
              {t.btn1}
            </button>
            <button class="bg-transparent text-white border border-white/30 px-8 py-4 rounded-xl font-label-md text-base font-bold hover:bg-white/10 transition-all active:scale-98">
              {t.btn2}
            </button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="es" />
</Layout>
