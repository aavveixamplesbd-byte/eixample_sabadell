---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import { newsArticles } from '../../../data/newsData';

export async function getStaticPaths() {
  return newsArticles.map((article) => ({
    params: { slug: article.slug.es },
    props: { article }
  }));
}

const { article } = Astro.props;
const alternateUrl = `/noticies/${article.slug.ca}`;

const dateFormatted = new Date(article.date).toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
---

<Layout title={`${article.title.es} - Eixample Sabadell`} lang="es">
  <Navbar client:load />
  <Breadcrumbs lang="es" items={[
    { label: 'Noticias', href: '/es/noticies' },
    { label: article.title.es }
  ]} />

  <main class="py-12 px-margin-mobile md:px-margin-desktop max-w-4xl mx-auto w-full">
    <article class="flex flex-col gap-8">
      {/* Header Info */}
      <header class="flex flex-col gap-4">
        <div class="flex flex-wrap items-center gap-3">
          <span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-label-sm font-label-sm uppercase tracking-widest font-semibold">
            {article.category.es}
          </span>
          <span class="text-outline-variant font-medium">•</span>
          <span class="text-secondary font-label-md text-sm">{dateFormatted}</span>
          <span class="text-outline-variant font-medium">•</span>
          <span class="text-secondary font-label-md text-sm">{article.readTime.es}</span>
        </div>
        <h1 class="font-display-lg text-3xl sm:text-4xl md:text-5xl font-extrabold text-on-surface leading-tight">
          {article.title.es}
        </h1>
      </header>

      {/* Main Image */}
      <div class="w-full h-[350px] sm:h-[450px] rounded-3xl overflow-hidden shadow-md border border-outline-variant/30">
        <img 
          src={article.image} 
          alt={article.alt.es} 
          class="w-full h-full object-cover"
        />
      </div>

      {/* Article Content */}
      <div class="font-body-lg text-body-lg text-on-surface-variant leading-relaxed flex flex-col gap-6 max-w-3xl">
        {article.content.es.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>

      {/* Back Button */}
      <div class="border-t border-outline-variant/20 pt-10 mt-8 flex">
        <a 
          href="/es/noticies" 
          class="inline-flex items-center gap-2 text-primary font-label-md font-bold hover:gap-3 transition-all"
        >
          <span class="material-symbols-outlined text-[20px]">arrow_back</span>
          Volver a las noticias
        </a>
      </div>
    </article>
  </main>

  <Footer lang="es" />

  {/* Pass alternate language URL to Navbar */}
  <script is:inline define:vars={{ alternateUrl }}>
    window.alternateLangUrl = alternateUrl;
  </script>
</Layout>
