---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
---

<Layout title="Eixample Industrial Sabadell">
	<Navbar client:load />
	<main class="px-margin-mobile max-w-max-width mx-auto w-full">
		<header class="text-center py-20 max-w-2xl mx-auto">
			<h2 class="font-display-lg text-4xl sm:text-5xl font-bold mb-4 text-primary">
				Eixample Industrial Sabadell
			</h2>
			<p class="font-body-md text-on-surface-variant text-lg">
				El projecte s'ha configurat correctament amb Tailwind, Astro, React i TypeScript. Comença a portar la resta de seccions des de la carpeta <code>/designs</code>.
			</p>
		</header>
	</main>
</Layout>
