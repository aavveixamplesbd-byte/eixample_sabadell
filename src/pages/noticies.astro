---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import NewsPortal from '../components/NewsPortal';
import Footer from '../components/Footer.astro';
import { getArticles } from '../utils/news';

const articles = await getArticles();
const sortedArticles = [...articles].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const featuredArticle = articles.find(a => a.featured) || sortedArticles[0];
const remainingArticles = sortedArticles.filter(a => a.id !== featuredArticle.id);

const featuredDateFormatted = new Date(featuredArticle.date).toLocaleDateString('ca-ES', { day: 'numeric', month: 'long', year: 'numeric' });

const t = {
  headerBadge: "Actualitat del Barri",
  headerTitle: "Notícies i Activitats",
  headerDesc: "L'actualitat del cor industrial de Sabadell. Descobreix els esdeveniments, projectes urbanístics i cròniques històriques del barri.",
  featuredAuthor: "Redacció AVES",
  newsletterTitle: "Estigues connectat",
  newsletterDesc: "Subscriu-te al nostre butlletí mensual i no perdis cap detall sobre les activitats, assemblees i notícies rellevants de l'Eixample Sabadell.",
  newsletterPlaceholder: "El teu correu electrònic",
  newsletterBtn: "Subscriure'm",
  newsletterConsent: "En subscriure't, acceptes la nostra Política de Privacitat. No t'enviarem correus brossa.",
  sidebarBadge: "Comunitat",
  sidebarBody: "Unim-nos per fer un barri millor, dia rere dia."
};
---

<Layout title="Notícies i Activitats - Eixample Sabadell" lang="ca">
  <Navbar client:load />
  <Breadcrumbs lang="ca" items={[{ label: 'Notícies' }]} />
  
  <main class="pt-6 pb-20 px-margin-mobile md:px-margin-desktop max-w-max-width mx-auto w-full">
    {/* Page Title Header */}
    <header class="my-12">
      <span class="font-label-md text-label-md text-primary uppercase tracking-[0.2em] bg-primary/10 px-4 py-1.5 rounded-full inline-block mb-4 font-semibold">
        {t.headerBadge}
      </span>
      <h1 class="font-display-lg text-4xl sm:text-5xl font-extrabold text-on-surface mb-4">
        {t.headerTitle}
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl leading-relaxed">
        {t.headerDesc}
      </p>
    </header>

    <section class="mb-16">
      <a 
        href={`/noticies/${featuredArticle.slug.ca}`}
        class="relative block w-full h-[400px] sm:h-[500px] rounded-2xl overflow-hidden group cursor-pointer border border-outline-variant/30"
      >
        <img 
          alt={featuredArticle.alt.ca} 
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" 
          src={featuredArticle.image}
          onerror="this.onerror=null; this.src='/og-image.png';"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/35 to-transparent flex flex-col justify-end p-6 sm:p-12 text-left">
          <div class="mb-4">
            <span class="bg-primary-fixed text-on-primary-fixed-variant px-3 py-1 rounded-full text-label-sm font-label-sm uppercase tracking-widest font-semibold">
              {featuredArticle.category.ca}
            </span>
          </div>
          <h2 class="font-headline-lg text-2xl sm:text-4xl text-white mb-4 max-w-3xl font-bold leading-tight group-hover:text-primary-fixed transition-colors">
            {featuredArticle.title.ca}
          </h2>
          <p class="text-white/80 font-body-md text-body-md max-w-xl mb-6 line-clamp-2">
            {featuredArticle.description.ca}
          </p>
          <div class="flex items-center gap-6 text-white/90">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-[20px]">calendar_today</span>
              <span class="text-label-sm font-label-sm font-medium">{featuredDateFormatted}</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-[20px]">person</span>
              <span class="text-label-sm font-label-sm font-medium">{t.featuredAuthor}</span>
            </div>
          </div>
        </div>
      </a>
    </section>

    {/* Interactive React News Grid and Filters */}
    <NewsPortal lang="ca" articles={remainingArticles} client:load />

    {/* Page Newsletter Section */}
    <section class="mt-32">
      <div class="bg-surface-container-low rounded-2xl overflow-hidden border border-outline-variant/20 flex flex-col lg:flex-row w-full">
        <div class="p-8 sm:p-16 lg:w-3/5">
          <h2 class="font-display-lg text-3xl sm:text-4xl font-extrabold text-on-surface mb-6">{t.newsletterTitle}</h2>
          <p class="font-body-lg text-body-lg text-on-surface-variant mb-10 leading-relaxed">
            {t.newsletterDesc}
          </p>
          <form class="flex flex-col sm:flex-row gap-4" onSubmit="event.preventDefault()">
            <input 
              class="flex-grow bg-white border border-outline-variant/30 rounded-lg px-6 py-4 text-body-md focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all" 
              placeholder={t.newsletterPlaceholder} 
              type="email"
              required
            />
            <button 
              type="submit" 
              class="bg-primary hover:bg-primary-container text-white px-10 py-4 rounded-lg font-label-md text-label-md font-bold transition-all whitespace-nowrap active:scale-98"
            >
              {t.newsletterBtn}
            </button>
          </form>
          <p class="mt-6 font-label-sm text-label-sm text-outline">
            {t.newsletterConsent}
          </p>
        </div>
        <div class="lg:w-2/5 relative h-64 lg:h-auto bg-primary-container/20 flex items-center justify-center overflow-hidden p-8">
          <span class="material-symbols-outlined text-[120px] text-primary/10 absolute -rotate-12 transform -translate-x-12">newspaper</span>
          <span class="material-symbols-outlined text-[180px] text-primary/5 absolute rotate-12 transform translate-x-20 translate-y-20">mail</span>
          <div class="relative z-10 bg-white/70 backdrop-blur-md p-8 rounded-xl max-w-xs text-center border border-outline-variant/15">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="material-symbols-outlined text-primary text-[32px]">verified</span>
            </div>
            <h4 class="font-headline-md text-headline-md mb-2 text-primary font-bold">{t.sidebarBadge}</h4>
            <p class="font-body-md text-body-md text-on-surface-variant">{t.sidebarBody}</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="ca" />
</Layout>
