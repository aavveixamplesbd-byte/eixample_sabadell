---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';

const alternateUrl = "/es/qui-som";

const t = {
  headerBadge: "L'Associació de Veïns",
  headerTitle: "Qui Som",
  headerDesc: "Treballem pel barri de l'Eixample de Sabadell. Coneix les persones que formen part de la junta de l'associació i ajuden a millorar el dia a dia de la comunitat.",
  missionTitle: "La nostra missió",
  missionDesc: "L'Associació de Veïns Eixample Sabadell (AVES) és una organització sense ànim de lucre fundada per defensar els interessos del veïnat, conservar el nostre valuós patrimoni industrial, promoure la cultura local i impulsar la millora dels espais urbans.",
  valuesTitle: "Els nostres valors",
  values: [
    { title: "Comunitat", desc: "Fomentem la cohesió social i la convivència solidària entre tots els veïns i veïnes del barri." },
    { title: "Patrimoni", desc: "Preservem el llegat històric de les antigues filatures, xemeneies i el passat obrer de Sabadell." },
    { title: "Sostenibilitat", desc: "Impulsem millores en mobilitat, espais verds i eficiència energètica per un barri més saludable." }
  ],
  boardTitle: "Membres de la Junta",
  boardDesc: "L'equip que coordina les assemblees, pressupostos, activitats culturals i relacions amb l'Ajuntament."
};

const boardMembers = [
  { name: "Jordi Esque i Florés", role: "President", initial: "JE", color: "bg-teal-700/10 text-teal-800", image: "/jordi_esque_i_flores.png" },
  { name: "Joan-Maria Valls i Prats", role: "Secretari", initial: "JM", color: "bg-cyan-700/10 text-cyan-800", image: "/Gemini_Generated_Image_rmj06ormj06ormj0.png", imgStyle: "width: 175%; max-width: none; height: auto; position: absolute; top: -10%; left: -38%;" },
  { name: "Jauma (Cognom per definir)", role: "Tresorer", initial: "JA", color: "bg-sky-700/10 text-sky-800", image: "/Gemini_Generated_Image_5eu6t55eu6t55eu6.png", imgStyle: "width: 199%; max-width: none; height: auto; position: absolute; top: -10%; left: -49%;" },
  { name: "Araceli Bernat Carbonell", role: "Vocal", initial: "AP", color: "bg-violet-700/10 text-violet-800", image: "/Gemini_Generated_Image_5ikprb5ikprb5ikp.png" },
  { name: "Iolanda Furriols i Busquets", role: "Vocal", initial: "IF", color: "bg-fuchsia-700/10 text-fuchsia-800", image: "/iolanda_furriols_i_busquets.png", imgStyle: "width: 170%; max-width: none; height: auto; position: absolute; top: -12%; left: -35%;" },
  { name: "José Antonio Olivari", role: "Vocal", initial: "JO", color: "bg-indigo-700/10 text-indigo-800", image: "/Gemini_Generated_Image_6i5esb6i5esb6i5e.png", imgStyle: "width: 107%; max-width: none; height: auto; position: absolute; top: -17%; left: -3%;" },
  { name: "Oriol Valbuena", role: "Vocal", initial: "OV", color: "bg-rose-700/10 text-rose-800", image: "/oriol_valbuena.png", imgStyle: "width: 165%; max-width: none; height: auto; position: absolute; top: -3%; left: -35%;" }
];
---

<Layout title="Qui som - Eixample Sabadell" lang="ca">
  <Navbar client:load />
  <Breadcrumbs lang="ca" items={[{ label: 'Qui som' }]} />
  
  <main class="py-12 px-margin-mobile md:px-margin-desktop max-w-max-width mx-auto w-full">
    {/* Page Title Header */}
    <header class="my-12">
      <span class="font-label-md text-label-md text-primary uppercase tracking-[0.2em] bg-primary/10 px-4 py-1.5 rounded-full inline-block mb-4 font-semibold">
        {t.headerBadge}
      </span>
      <h1 class="font-display-lg text-4xl sm:text-5xl font-extrabold text-on-surface mb-4">
        {t.headerTitle}
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl leading-relaxed">
        {t.headerDesc}
      </p>
    </header>

    {/* Mission and Values Section */}
    <section class="grid grid-cols-1 lg:grid-cols-3 gap-12 my-20">
      <div class="lg:col-span-1 bg-surface-container-low p-8 sm:p-12 rounded-3xl border border-outline-variant/15 flex flex-col justify-center">
        <h2 class="font-display-lg text-2xl sm:text-3xl font-extrabold text-primary mb-6">{t.missionTitle}</h2>
        <p class="font-body-md text-on-surface-variant leading-relaxed">
          {t.missionDesc}
        </p>
      </div>

      <div class="lg:col-span-2 flex flex-col gap-6">
        <h2 class="font-display-lg text-2xl sm:text-3xl font-extrabold text-on-surface mb-4">{t.valuesTitle}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {t.values.map((value) => (
            <div class="bg-white p-6 rounded-2xl border border-outline-variant/10 shadow-sm hover:shadow-md transition-all">
              <span class="material-symbols-outlined text-primary text-[36px] mb-4">done_outline</span>
              <h3 class="font-headline-md text-lg font-bold text-on-surface mb-2">{value.title}</h3>
              <p class="font-body-sm text-sm text-on-surface-variant leading-relaxed">{value.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Junta Members Grid */}
    <section class="my-24">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="font-display-lg text-3xl sm:text-4xl font-extrabold text-on-surface mb-4">
          {t.boardTitle}
        </h2>
        <p class="font-body-md text-on-surface-variant leading-relaxed">
          {t.boardDesc}
        </p>
      </div>

      {/* President Card (Centered on top row) */}
      <div class="flex justify-center mb-8">
        <div class="w-full sm:max-w-[380px]">
          <div class="bg-surface-container-low border border-outline-variant/15 rounded-3xl p-8 flex items-center gap-6 group hover:-translate-y-1 transition-all duration-300 shadow-sm hover:shadow-md">
            {/* Member Photo or Initials Avatar */}
            {boardMembers[0].image ? (
              <div class="w-16 h-16 rounded-full overflow-hidden shrink-0 relative group-hover:scale-105 transition-all">
                <img 
                  src={boardMembers[0].image} 
                  alt={boardMembers[0].name} 
                  class="object-cover" 
                  style={boardMembers[0].imgStyle || "width: 100%; height: 100%;"}
                />
              </div>
            ) : (
              <div class={`w-16 h-16 rounded-full ${boardMembers[0].color} flex items-center justify-center font-bold text-xl tracking-wider select-none shrink-0 group-hover:scale-105 transition-all`}>
                {boardMembers[0].initial}
              </div>
            )}
            
            <div class="flex flex-col">
              <h3 class="font-headline-md text-xl font-bold text-on-surface group-hover:text-primary transition-colors">
                {boardMembers[0].name}
              </h3>
              <p class="font-body-sm text-sm text-on-surface-variant mt-1">
                {boardMembers[0].role}
              </p>
            </div>
          </div>
        </div>
      </div>

      {/* Remaining Board Members Grid */}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {boardMembers.slice(1).map((member) => (
          <div class="bg-surface-container-low border border-outline-variant/15 rounded-3xl p-8 flex items-center gap-6 group hover:-translate-y-1 transition-all duration-300 shadow-sm hover:shadow-md">
            {/* Member Photo or Initials Avatar */}
            {member.image ? (
              <div class="w-16 h-16 rounded-full overflow-hidden shrink-0 relative group-hover:scale-105 transition-all">
                <img 
                  src={member.image} 
                  alt={member.name} 
                  class="object-cover" 
                  style={member.imgStyle || "width: 100%; height: 100%;"}
                />
              </div>
            ) : (
              <div class={`w-16 h-16 rounded-full ${member.color} flex items-center justify-center font-bold text-xl tracking-wider select-none shrink-0 group-hover:scale-105 transition-all`}>
                {member.initial}
              </div>
            )}
            
            <div class="flex flex-col">
              <h3 class="font-headline-md text-xl font-bold text-on-surface group-hover:text-primary transition-colors">
                {member.name}
              </h3>
              <p class="font-body-sm text-sm text-on-surface-variant mt-1">
                {member.role}
              </p>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>

  <Footer lang="ca" />

  {/* Pass alternate language URL to Navbar */}
  <script is:inline define:vars={{ alternateUrl }}>
    window.alternateLangUrl = alternateUrl;
  </script>
</Layout>
